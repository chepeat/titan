generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  supabaseId      String?        @unique
  name            String?
  role            Role           @default(USER)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  trainingPlanId  String?
  createdRoutines Routine[]      @relation("CoachRoutines")
  createdSessions Session[]      @relation("CoachSessions")
  createdPlans    TrainingPlan[] @relation("CoachPlans")
  trainingPlan    TrainingPlan?       @relation(fields: [trainingPlanId], references: [id])
  createdWeeks    Week[]                @relation("CoachWeeks")
  completedSessions SessionCompletion[]
}

model TrainingPlan {
  id          String  @id @default(cuid())
  name        String
  description String?
  coachId     String?
  coach       User?   @relation("CoachPlans", fields: [coachId], references: [id])
  users       User[]
  weeks       Week[]
}

model Week {
  id             String        @id @default(cuid())
  name           String?
  number         Int
  coachId        String?
  trainingPlanId String?
  sessions       Session[]
  coach          User?         @relation("CoachWeeks", fields: [coachId], references: [id])
  trainingPlan   TrainingPlan? @relation(fields: [trainingPlanId], references: [id])
}

model Session {
  id        String    @id @default(cuid())
  name      String
  weekId    String?
  dayNumber Int?
  order     Int?
  coachId   String?
  coach     User?     @relation("CoachSessions", fields: [coachId], references: [id])
  routines  Routine[]
  week      Week?               @relation(fields: [weekId], references: [id])
  completions SessionCompletion[]
}

model Routine {
  id          String        @id @default(cuid())
  name        String
  sessionId   String?
  order       Int?
  coachId     String?
  createdAt   DateTime      @default(now())
  description String?
  updatedAt   DateTime      @updatedAt
  coach       User?         @relation("CoachRoutines", fields: [coachId], references: [id])
  session     Session?      @relation(fields: [sessionId], references: [id])
  exercises   RoutineItem[]
}

model RoutineItem {
  id          String   @id @default(cuid())
  routineId   String
  exerciseId  String
  machineId   String?
  series      Int
  reps        Json
  restingTime Int
  order       Int
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  machine     Machine? @relation(fields: [machineId], references: [id])
  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String        @id @default(cuid())
  name         String
  description  String?
  videoFile    String?
  observations String?
  routines     RoutineItem[]
  machines     Machine[]     @relation("ExerciseMachines")
}

model Machine {
  id           String        @id @default(cuid())
  number       Int
  description  String
  imageFile    String?
  observations String?
  routines     RoutineItem[]
  exercises    Exercise[]    @relation("ExerciseMachines")
}

enum Role {
  ADMIN
  COACH
  USER
}

model SessionCompletion {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
}
