// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  COACH
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  supabaseId String? @unique
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A user (Socio) can be assigned to a training plan
  trainingPlan   TrainingPlan? @relation(fields: [trainingPlanId], references: [id])
  trainingPlanId String?

  // A coach can create many plans (optional relationship)
  createdPlans TrainingPlan[] @relation("CoachPlans")
}

model TrainingPlan {
  id          String  @id @default(cuid())
  name        String
  description String?
  weeks       Week[]

  // Relationships
  users   User[]
  coachId String?
  coach   User?   @relation("CoachPlans", fields: [coachId], references: [id])
}

model Week {
  id             String       @id @default(cuid())
  number         Int
  trainingPlanId String
  trainingPlan   TrainingPlan @relation(fields: [trainingPlanId], references: [id])
  days           Day[]
}

model Day {
  id       String    @id @default(cuid())
  number   Int
  weekId   String
  week     Week      @relation(fields: [weekId], references: [id])
  sessions Session[]
}

model Session {
  id       String    @id @default(cuid())
  name     String
  dayId    String
  day      Day       @relation(fields: [dayId], references: [id])
  order    Int
  routines Routine[]
}

model Routine {
  id        String        @id @default(cuid())
  name      String
  sessionId String
  session   Session       @relation(fields: [sessionId], references: [id])
  order     Int
  exercises RoutineItem[]
}

model RoutineItem {
  id          String   @id @default(cuid())
  routineId   String
  routine     Routine  @relation(fields: [routineId], references: [id])
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  machineId   String?
  machine     Machine? @relation(fields: [machineId], references: [id])
  series      Int
  reps        Json // Store as an array indicating reps per series like [12, 10, 8]
  restingTime Int // In seconds
  order       Int
}

model Exercise {
  id           String  @id @default(cuid())
  name         String
  description  String?
  videoFile    String?
  observations String?

  routines RoutineItem[]
  machines Machine[]     @relation("ExerciseMachines")
}

model Machine {
  id           String  @id @default(cuid())
  number       Int
  description  String
  imageFile    String?
  observations String?

  routines  RoutineItem[]
  exercises Exercise[]    @relation("ExerciseMachines")
}
